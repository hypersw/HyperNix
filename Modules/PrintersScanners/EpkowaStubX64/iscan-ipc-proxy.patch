+dnl  Use an out-of-process "stub" to run the proprietary esci-interpreter
+dnl  plugins when they can't be loaded natively (e.g. x86_64 plugins on an
+dnl  aarch64 host). When enabled, epkowa_ip.c's _load() forwards calls over
+dnl  a Unix socket to a per-scan helper process which does the dlopen.
+dnl
+dnl  --with-ipc-stub=PATH sets the compile-time default path to the helper
+dnl  executable. Overridable at run time via the EPKOWA_IPC_STUB env var.
+
+AC_MSG_CHECKING(whether to use the IPC proxy for interpreter plugins)
+AC_ARG_ENABLE(ipc-proxy,
+	      AC_HELP_STRING([--enable-ipc-proxy],
+			     [forward esci-interpreter calls to an out-of-process stub]),
+	      ,
+	      [enable_ipc_proxy=no])
+AC_MSG_RESULT([$enable_ipc_proxy])
+if test x$enable_ipc_proxy = xyes; then
+  AC_DEFINE([USE_IPC_PROXY], 1,
+	    [Define to 1 to use an out-of-process stub for esci-interpreter plugins.])
+  AC_ARG_WITH(ipc-stub,
+	      AC_HELP_STRING([--with-ipc-stub=PATH],
+			     [default path to the stub helper executable]),
+	      [ipc_stub_path=$withval],
+	      [ipc_stub_path=/usr/libexec/epkowa-stub-x64])
+  AC_DEFINE_UNQUOTED([IPC_STUB_PATH], ["$ipc_stub_path"],
+		     [Default path to the interpreter stub executable.])
+fi
+AM_CONDITIONAL(ENABLE_IPC_PROXY, test x$enable_ipc_proxy = xyes)
+
+
 dnl  Facilitate builds on architectures other than i386 and friends.
 
