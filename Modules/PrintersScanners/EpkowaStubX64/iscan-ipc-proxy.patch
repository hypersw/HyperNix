+/* epkowa_ipc.h — proxy-side IPC interface (see epkowa_ipc.c).
+ *
+ * These functions mirror the signatures expected by epkowa_ip.c's
+ * `interpreter_type` function-pointer slots, so _load() can fill the
+ * slots with &ipc_int_init (etc.) when --enable-ipc-proxy is on.
+ */
+
+#ifndef epkowa_ipc_h_included
+#define epkowa_ipc_h_included
+
+#include <stdint.h>
+#include <stddef.h>
+
+/* "defines.h" provides iscan's own `typedef enum { false, true } bool`.
+ * Using <stdbool.h>'s _Bool here would make these declarations
+ * type-incompatible with the `interpreter_type` fn-pointer slots that
+ * epkowa_ip.c assigns them to. */
+#include "defines.h"
+#include "epkowa_ip_api.h"
+
+#ifdef __cplusplus
+extern "C" {
+#endif
+
+/* Lifecycle: spawn a stub process and load the given interpreter library
+ * inside it. Sets *has_ctrl to whether the plugin exports
+ * int_init_with_ctrl (vs. only int_init). Call ipc_unload_interpreter()
+ * to tear down. */
+bool ipc_load_interpreter(const char *library_name, bool *has_ctrl);
+void ipc_unload_interpreter(void);
+
+/* IPC-backed versions of the interpreter API. Installed into
+ * interpreter_type by epkowa_ip.c:_load() when USE_IPC_PROXY. */
+bool ipc_int_init           (int fd, io_callback *read_cb, io_callback *write_cb);
+bool ipc_int_init_with_ctrl (int fd, io_callback *read_cb, io_callback *write_cb,
+                             ctrl_callback *ctrl_cb);
+void ipc_int_fini           (void);
+int  ipc_int_read           (void *buffer, size_t length);
+int  ipc_int_write          (void *buffer, size_t length);
+void ipc_int_power_saving_mode (void);
+int  ipc_function_s_0       (unsigned int offset, unsigned int width,
+                             unsigned int resolution, unsigned int opt_resolution,
+                             double *table);
+void ipc_function_s_1       (uint8_t *in_buf, uint8_t *out_buf,
+                             unsigned int width, bool color, double *table);
+
+#ifdef __cplusplus
+} /* extern "C" */
+#endif
+
+#endif /* !epkowa_ipc_h_included */
